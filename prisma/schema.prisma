generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/hot_print_website/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  AGENCY
  ADMIN
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          UserRole  @default(CLIENT)
  phone         String?
  company       String?
  cashback      Float     @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  reviews       Review[]
  referralsSent Referral[] @relation("ReferrerRelation")
  referralsReceived Referral[] @relation("ReferredRelation")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Product {
  id            String   @id @default(cuid())
  name          String
  nameRo        String?
  nameEn        String?
  slug          String   @unique
  description   String
  descriptionRo String?
  descriptionEn String?
  category      String
  categoryRo    String?
  categoryEn    String?
  imageUrl      String?
  minPrice      Float?
  maxPrice      Float?
  printTech     String?
  featured      Boolean  @default(false)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orders        Order[]
}

model Service {
  id          String   @id @default(cuid())
  name        String
  nameRo      String?
  nameEn      String?
  slug        String   @unique
  shortDesc   String
  shortDescRo String?
  shortDescEn String?
  fullDesc    String
  fullDescRo  String?
  fullDescEn  String?
  imageUrl    String?
  icon        String?
  features    String[]
  featuresRo  String[]
  featuresEn  String[]
  minPrice    Float?
  featured    Boolean  @default(false)
  active      Boolean  @default(true)
  seoTitle    String?
  seoDesc     String?
  seoH1       String?
  aeoAnswer   String?
  aeoAnswerRo String?
  aeoAnswerEn String?
  faqJson     String?
  faqJsonRo   String?
  faqJsonEn   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String
  productId       String?
  serviceName     String?
  description     String?
  quantity        Int         @default(1)
  totalPrice      Float?
  status          OrderStatus @default(PENDING)
  fileCloudPath   String?
  fileIsPublic    Boolean     @default(false)
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            User        @relation(fields: [userId], references: [id])
  product         Product?    @relation(fields: [productId], references: [id])
}

model DieCutForm {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  category    String
  dimensions  String
  knifeType   String
  imageUrl    String?
  fileCloudPath String?
  fileIsPublic  Boolean @default(true)
  available   Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String
  imageUrl    String?
  author      String   @default("Hot Print")
  tags        String[]
  published   Boolean  @default(true)
  seoTitle    String?
  seoDesc     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Review {
  id        String   @id @default(cuid())
  userId    String?
  author    String
  company   String?
  rating    Int      @default(5)
  text      String
  approved  Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())
}

model Referral {
  id          String   @id @default(cuid())
  referrerId  String
  referredId  String
  bonus       Float    @default(0)
  createdAt   DateTime @default(now())
  referrer    User     @relation("ReferrerRelation", fields: [referrerId], references: [id])
  referred    User     @relation("ReferredRelation", fields: [referredId], references: [id])
}

model PortfolioItem {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  category    String
  description String?
  imageUrl    String?
  client      String?
  technology  String?
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
